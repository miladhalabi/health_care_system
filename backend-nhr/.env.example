# Server Config
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=your_jwt_secret_here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Database
# Connect to PostgreSQL. See: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@localhost:5432/health_care_system?schema=public"

# Logging
LOG_LEVEL=info
