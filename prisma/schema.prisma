generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String
  name      String
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())

  doctorAppointments       Appointment[] @relation("DoctorAppointments")
  receptionistAppointments Appointment[] @relation("ReceptionistAppointments")
}

model Clinic {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users        User[]
  appointments Appointment[]
}

model NationalPatient {
  id             String          @id @default(uuid())
  nationalId     String          @unique
  fullName       String
  dateOfBirth    DateTime
  gender         String
  bloodType      String?
  address        String?
  phone          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  auditLogs      AuditLog[]
  consents       Consent[]
  encounters     Encounter[]
  medicalRecords MedicalRecord[]
  appointments   Appointment[]
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  patient         NationalPatient @relation(fields: [patientId], references: [id])
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  doctorId        String
  doctor          User     @relation("DoctorAppointments", fields: [doctorId], references: [id])
  receptionistId  String?
  receptionist    User?    @relation("ReceptionistAppointments", fields: [receptionistId], references: [id])
  appointmentDate DateTime
  status          String   // SCHEDULED, COMPLETED, CANCELLED
  reason          String?
  createdAt       DateTime @default(now())
}

model Encounter {
  id                    String          @id @default(uuid())
  patientId             String
  clinicId              String
  doctorId              String
  date                  DateTime        @default(now())
  diagnosis             String
  notes                 String?
  treatmentPlan         String?
  encounterType         String
  status                String          @default("ACTIVE")
  supersedesEncounterId String?
  idempotencyKey        String?         @unique
  createdAt             DateTime        @default(now())
  patient               NationalPatient @relation(fields: [patientId], references: [id])
}

model MedicalRecord {
  id          String          @id @default(uuid())
  patientId   String
  type        String
  title       String
  description String?
  status      String
  recordedAt  DateTime        @default(now())
  patient     NationalPatient @relation(fields: [patientId], references: [id])
}

model Consent {
  id        String          @id @default(uuid())
  patientId String
  clinicId  String
  status    String
  expiresAt DateTime?
  updatedAt DateTime        @updatedAt
  patient   NationalPatient @relation(fields: [patientId], references: [id])
}

model AuditLog {
  id        String           @id @default(uuid())
  patientId String?
  userId    String
  clinicId  String?
  action    String
  endpoint  String
  ipAddress String?
  details   String?
  timestamp DateTime         @default(now())
  patient   NationalPatient? @relation(fields: [patientId], references: [id])
}
